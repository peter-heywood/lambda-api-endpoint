# Local .terraform directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Sensitive variable files
*.tfvars
*.tfvars.json

# Local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Lock info files
terraform.tfstate.lock.info

# CLI configuration files
terraformrc
terraform.rc

# Optional: ignore plan output files
*tfplan*
